# Prefer uv-managed Python invocations.
prefix_rule(
    pattern = [["python", "python3"]],
    decision = "forbidden",
    justification = "Use `uv run` instead of `python` to keep the interpreter and dependencies consistent.",
    match = [
        "python script.py",
        "python3 -m pytest",
    ],
    not_match = [
        "uv run python script.py",
        "uv run python3 -m pytest",
    ],
)

prefix_rule(
    pattern = [["pip", "pip3"]],
    decision = "forbidden",
    justification = "Use `uv add/remove` for dependencies or `uv run --with` for one-off scripts instead of `pip`.",
    match = [
        "pip install requests",
        "pip3 install -r requirements.txt",
    ],
    not_match = [
        "uv add requests",
        "uv run --with requests python script.py",
    ],
)

prefix_rule(
    pattern = [["grep", "egrep", "fgrep"]],
    decision = "prompt",
    justification = "Prefer `rg` (RipGrep) for text and file searches; use `grep` only when `rg` is unavailable or a command truly needs grep semantics.",
    match = [
        "grep pattern file.txt",
        "grep -R pattern .",
        "egrep 'foo|bar' file.txt",
        "fgrep pattern file.txt",
    ],
    not_match = [
        "rg pattern file.txt",
        "rg -n pattern .",
        "git grep pattern",
    ],
)
