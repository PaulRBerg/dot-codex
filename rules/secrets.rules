# Prompt before `pass` commands that reveal or mutate secrets.
prefix_rule(
    pattern = [["pass"], ["show", "insert", "edit", "rm"]],
    decision = "prompt",
    justification = "`pass` commands can reveal or mutate secrets; verify path and output handling.",
    match = [
        "pass show github/token",
        "pass insert service/token",
        "pass rm service/token",
    ],
    not_match = [
        "pass ls",
        "pass git status",
    ],
)

# Prompt before macOS keychain reads that can print secrets.
prefix_rule(
    pattern = [["security"], ["find-generic-password", "find-internet-password"]],
    decision = "prompt",
    justification = "macOS keychain reads can print secrets; verify the account/service and redact outputs.",
    match = [
        "security find-generic-password -s service -w",
        "security find-internet-password -s example.com -w",
    ],
    not_match = [
        "security list-keychains",
        "security find-certificate -a",
    ],
)

# Prompt before `sops` decrypt/encrypt/edit that can expose secrets.
prefix_rule(
    pattern = [["sops"], ["-d", "--decrypt", "--encrypt", "--rotate", "edit"]],
    decision = "prompt",
    justification = "`sops` commands can reveal or mutate secrets; verify recipients and avoid printing decrypted content.",
    match = [
        "sops -d secrets.yaml",
        "sops edit secrets.yaml",
    ],
    not_match = [
        "sops --version",
    ],
)
